{
  "title": "Event Platform — End-to-End Monitoring",
  "uid":   "event-platform-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["kafka", "event-platform", "microservices"],

  "templating": {
    "list": [
      {
        "name":  "instance",
        "type":  "query",
        "query": "label_values(up, instance)",
        "label": "Service Instance"
      }
    ]
  },

  "panels": [
    {
      "id":    1,
      "title": "Service Availability",
      "type":  "stat",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 4 },
      "targets": [
        {
          "expr":    "up",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red",   "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
          ]
        }
      }
    },
    {
      "id":    2,
      "title": "Events Published / sec",
      "type":  "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr":         "rate(kafka_events_published_total[1m])",
          "legendFormat": "published/s"
        },
        {
          "expr":         "rate(kafka_events_failed_total[1m])",
          "legendFormat": "failed/s"
        }
      ]
    },
    {
      "id":    3,
      "title": "Kafka Publish Latency (p50/p95/p99)",
      "type":  "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr":         "histogram_quantile(0.50, rate(kafka_publish_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr":         "histogram_quantile(0.95, rate(kafka_publish_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr":         "histogram_quantile(0.99, rate(kafka_publish_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id":    4,
      "title": "Aggregates Consumed / sec",
      "type":  "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr":         "rate(consumer_aggregates_consumed_total[1m])",
          "legendFormat": "aggregates/s"
        }
      ]
    },
    {
      "id":    5,
      "title": "Alerts Fired / sec",
      "type":  "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr":         "rate(consumer_alerts_consumed_total[1m])",
          "legendFormat": "alerts/s"
        }
      ]
    },
    {
      "id":    6,
      "title": "Consumer Errors / sec",
      "type":  "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 6 },
      "targets": [
        {
          "expr":         "rate(consumer_errors_total[1m])",
          "legendFormat": "errors/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red",   "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id":    7,
      "title": "JVM Heap Usage",
      "type":  "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 6 },
      "targets": [
        {
          "expr":         "jvm_memory_used_bytes{area='heap'} / jvm_memory_max_bytes{area='heap'} * 100",
          "legendFormat": "{{instance}} heap%"
        }
      ]
    },
    {
      "id":    8,
      "title": "Tracked Event Types",
      "type":  "stat",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 4 },
      "targets": [
        {
          "expr":         "consumer_aggregates_tracked",
          "legendFormat": "event types"
        }
      ]
    },
    {
      "id":    9,
      "title": "Active Firing Alerts",
      "type":  "alertlist",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
      "options": {
        "alertInstanceLabelFilter": "",
        "dashboardAlerts": false,
        "stateFilter": { "firing": true }
      }
    }
  ]
}
